--TEST--
017: FOLD: narrow MUL result canonicalized before EQ
--ARGS--
-O2 --save
--CODE--
{
	uintptr_t c_1 = 0;
	bool c_2 = 0;
	bool c_3 = 1;
	uint8_t c_4 = 16;
	uint8_t c_5 = 0;
	l_1 = START(l_4);
	uint8_t d_2 = MUL(c_4, c_4);
	bool d_3 = EQ(d_2, c_5);
	l_4 = RETURN(l_1, d_3);
}
--EXPECT--
{
	uintptr_t c_1 = 0;
	bool c_2 = 0;
	bool c_3 = 1;
	l_1 = START(l_2);
	l_2 = RETURN(l_1, c_3);
}
